<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>RetakeSpawnEditor</RootNamespace>
    <AssemblyName>RetakeSpawnEditor</AssemblyName>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CounterStrikeSharp.API" Version="1.0.228" />
  </ItemGroup>

  <Target Name="SyncPluginArtifacts" AfterTargets="Build" Condition="'$(OS)' == 'Windows_NT'">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)\BuildScripts\Sync-PluginArtifacts.ps1&quot; -ProjectDir &quot;$(MSBuildProjectDirectory)&quot; -TargetDir &quot;$(MSBuildProjectDirectory)\bin\$(Configuration)\$(TargetFramework)&quot; -Version &quot;$(Version)&quot; -WorkspaceRoot &quot;$(MSBuildProjectDirectory)\..&quot;" />
  </Target>

</Project>
